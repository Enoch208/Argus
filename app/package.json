{
  "name": "argus-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Local AI in front of every Solana signature",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "cross-env ELECTRON_RUN_AS_NODE= electron-vite build && electron-builder",
    "build:mac": "cross-env ELECTRON_RUN_AS_NODE= electron-vite build && electron-builder --mac",
    "build:win": "cross-env ELECTRON_RUN_AS_NODE= electron-vite build && electron-builder --win",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:phishing": "tsx scripts/demo.ts phishing",
    "demo:safe": "tsx scripts/demo.ts safe",
    "demo:approve": "tsx scripts/demo.ts approve",
    "postinstall": "electron-builder install-app-deps"
  },
  "//deps": "better-sqlite3 backs the local scam-intel store; @types/better-sqlite3 is dev-only.",
  "//overrides": "uuid v10+ is ESM-only and breaks rpc-websockets (transitive of @solana/web3.js v1) when loaded from a CJS main process. Pinning to the last CJS major (v9) fixes this without forking either package. Drop when @solana/web3.js v2 lands or when our main goes ESM.",
  "overrides": {
    "uuid": "9.0.1"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^1.0.13",
    "@hugeicons/react": "^1.0.5",
    "@node-rs/argon2": "^2.0.2",
    "@qvac/sdk": "^0.10.2",
    "@solana/web3.js": "^1.95.4",
    "@tanstack/react-query": "^5.59.20",
    "@tetherto/wdk-wallet-solana": "^1.0.0-beta.8",
    "better-sqlite3": "^12.9.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "node-llama-cpp": "^3.18.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hotkeys-hook": "^4.6.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@tailwindcss/vite": "^4.0.0-beta.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^10.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^9.14.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.0.0-beta.6",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  }
}
